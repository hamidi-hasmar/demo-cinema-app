// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Movie {
  id              Int      @id @default(autoincrement())
  title           String   @unique
  synopsis        String
  durationMinutes Int
  language        String
  genre           String
  rating          String
  posterUrl       String
  trailerUrl      String   @default("")
  cast            String   @default("")
  director        String   @default("")
  writers         String   @default("")
  averageRating   Float    @default(0)
  reviewCount     Int      @default(0)
  ratingBreakdown String   @default("[]")
  reviews         String   @default("[]")
  releaseDate     DateTime
  isNowShowing    Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  showtimes       Showtime[]
}

model Showtime {
  id         Int      @id @default(autoincrement())
  movieId    Int
  movie      Movie    @relation(fields: [movieId], references: [id], onDelete: Cascade)
  location   String
  cinemaHall String
  showDate   DateTime
  startTime  String
  ticketType String
  minPrice   Int
  maxPrice   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  seatLocks  SeatLock[]
  transactions BookingTransaction[]

  @@unique([movieId, location, cinemaHall, showDate, startTime])
}

model SeatLock {
  id         Int      @id @default(autoincrement())
  showtimeId Int
  showtime   Showtime @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  seatNumber String
  lockedBy   String
  status     String   @default("LOCKED")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([showtimeId, seatNumber])
}

model BookingTransaction {
  id            Int      @id @default(autoincrement())
  reference     String   @unique
  showtimeId    Int
  showtime      Showtime @relation(fields: [showtimeId], references: [id], onDelete: Cascade)
  ticketType    String
  location      String
  cinemaHall    String
  showDate      DateTime
  startTime     String
  seats         String
  concessions   String   @default("[]")
  ticketTotal   Int
  concessionTotal Int
  grandTotal    Int
  paymentMethod String
  cardLastFour  String   @default("")
  status        String   @default("PAID")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
